# ── Org (Phase 0) ──────────────────────────────────────────────────────────────
OKTA_ORG_URL=https://dev-XXXXXXXX.okta.com
OKTA_API_TOKEN=                       # SSWS setup token (scripts only; revoke after Phase 5)
OKTA_AI_MODE=agents                   # agents | xaa | obo   (org is subscribed → default agents)

# ── Login (Phase 2/3; OKTA_LOGIN_ISSUER derived: agents/xaa → OKTA_ORG_URL, obo → OKTA_ORG_URL/oauth2/default) ──
OKTA_WEB_CLIENT_ID=
OKTA_WEB_CLIENT_SECRET=
OKTA_REDIRECT_URI=http://localhost:3000/auth/callback
OKTA_POST_LOGOUT_URI=http://localhost:3000
SESSION_SECRET=                       # openssl rand -hex 32
SEED_USER_PASSWORD=                   # password for the 5 demo personas

# ── Agent identity (Phase 5) ──────────────────────────────────────────────────
OKTA_AGENT_CLIENT_ID=                 # Mode A: agent Client ID from Directory > AI Agents; Mode C: API-services app
OKTA_AGENT_CLIENT_SECRET=             # Mode C only
OKTA_AGENT_PRIVATE_JWK=               # Modes A/B: single-line private JWK (scripts/agent-keys.mjs)
OKTA_AGENT_KID=

# ── Resource server ──────────────────────────────────────────────────────────
RESOURCE_AUDIENCE=api://default
RESOURCE_BASE_URL=http://localhost:3001
RESOURCE_SERVER_URL=http://localhost:3001
USER_IDENTITY_CLAIM=sub               # Adjust only if Gate 5 decode says sub is not the email
WEB_ORIGIN=http://localhost:3000

# ── Agent / LLM ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                    # optional; empty => MOCK_LLM=true takes effect
ANTHROPIC_MODEL=claude-sonnet-4-6
MOCK_LLM=false
AGENT_TOOL_TRANSPORT=rest             # rest | mcp (Phase 8)

# ── Next.js public env (available client-side) ───────────────────────────────
NEXT_PUBLIC_OKTA_ORG_URL=             # same as OKTA_ORG_URL (for System Log deep link in /audit)

# ── Misc ──────────────────────────────────────────────────────────────────────
DB_PATH=                              # optional override; defaults to apps/resource-server/data/benefits.sqlite
NODE_ENV=development
